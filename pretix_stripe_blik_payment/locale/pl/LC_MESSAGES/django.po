#: .\pretix_stripe_blik_payment\apps.py:39
#: .\pretix_stripe_blik_payment\payment.py:21
msgid "BLIK"
msgstr "BLIK"

#: .\pretix_stripe_blik_payment\apps.py:42
msgid ""
"Some payment methods might need to be enabled in the settings of your Stripe "
"account before they work properly."
msgstr ""
"Niektóre metody płatności mogą wymagać aktywacji w ustawieniach konta "
"Stripe, aby działały poprawnie."

#: .\pretix_stripe_blik_payment\payment.py:20
msgid "BLIK via Stripe"
msgstr "BLIK przez Stripe"

#: .\pretix_stripe_blik_payment\payment.py:26
msgid "You will be able to pay after placing an order."
msgstr "Będziesz mógł dokonać płatności po złożeniu zamówienia."

#: .\pretix_stripe_blik_payment\templates\pretix_stripe_blik_payment\pending_blik_code_form.html:3
msgid ""
"To complete your payment, open your banking app, generate a BLIK code, and "
"enter it below."
msgstr ""
"Aby dokończyć płatność, otwórz swoją aplikację bankową, wygeneruj kod BLIK i "
"wpisz go poniżej."

#: .\pretix_stripe_blik_payment\templates\pretix_stripe_blik_payment\pending_blik_code_form.html:8
msgid "BLIK code"
msgstr "Kod BLIK"

#: .\pretix_stripe_blik_payment\templates\pretix_stripe_blik_payment\pending_blik_code_form.html:12
msgid "The code is valid for 2 minutes."
msgstr "Kod jest ważny przez 2 minuty."

#: .\pretix_stripe_blik_payment\templates\pretix_stripe_blik_payment\pending_blik_code_form.html:14
msgid "Pay with BLIK"
msgstr "Zapłać przez BLIK"

#: .\pretix_stripe_blik_payment\views.py:18
msgid "Invalid link."
msgstr "Nieprawidłowy link."

#~ msgid ""
#~ "You will be asked to enter a 6-digit code from your banking app on the "
#~ "confirmation page, right before placing your order."
#~ msgstr ""
#~ "Na stronie potwierdzenia, tuż przed złożeniem zamówienia, zostaniesz "
#~ "poproszony o wpisanie 6-cyfrowego kodu ze swojej aplikacji bankowej."

#~ msgid "Please enter a valid 6-digit BLIK code."
#~ msgstr "Proszę wprowadzić poprawny 6-cyfrowy kod BLIK."